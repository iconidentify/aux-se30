install:: resize
	@if [ -d $(DESTDIR)$(BINDIR) ]; then set +x; \
	else (set -x; $(MKDIRHIER) $(DESTDIR)$(BINDIR)); fi
	$(INSTALL) $(INSTALLFLAGS) $(INSTPGMFLAGS)  resize $(DESTDIR)$(BINDIR)/resize

install:: XTerm.ad
	@if [ -d $(DESTDIR)$(XAPPLOADDIR) ]; then set +x; \
	else (set -x; $(MKDIRHIER) $(DESTDIR)$(XAPPLOADDIR)); fi
	$(INSTALL) $(INSTALLFLAGS) $(INSTAPPFLAGS) XTerm.ad $(DESTDIR)$(XAPPLOADDIR)/XTerm

install.man:: xterm.man
	@if [ -d $(DESTDIR)$(MANDIR) ]; then set +x; \
	else (set -x; $(MKDIRHIER) $(DESTDIR)$(MANDIR)); fi
	@(TMP=/tmp/tmp.$$$$; \
	$(RM) $${TMP}; \
	echo "  formatting" xterm.man "..."; \
	tbl xterm.man | neqn | nroff -man | compress > $${TMP}; \
	(set -x; $(INSTALL) -c $(INSTMANFLAGS) $${TMP} \
	$(DESTDIR)$(MANDIR)/xterm.$(MANSUFFIX).Z); \
	$(RM) $${TMP})

install.man:: resize.man
	@if [ -d $(DESTDIR)$(MANDIR) ]; then set +x; \
	else (set -x; $(MKDIRHIER) $(DESTDIR)$(MANDIR)); fi
	@(TMP=/tmp/tmp.$$$$; \
	$(RM) $${TMP}; \
	echo "  formatting" resize.man "..."; \
	tbl resize.man | neqn | nroff -man | compress > $${TMP}; \
	(set -x; $(INSTALL) -c $(INSTMANFLAGS) $${TMP} \
	$(DESTDIR)$(MANDIR)/resize.$(MANSUFFIX).Z); \
	$(RM) $${TMP})

